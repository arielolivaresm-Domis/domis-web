{
  "$schema": "domis-design-system/v1",
  "brand": "DOMIS™",
  "source": "domis.cl — extraído 2026-05-25",

  "color": {
    "background": {
      "base":        { "value": "#020617", "tw": "slate-950", "use": "body / fondo global" },
      "surface":     { "value": "#0F172A", "tw": "slate-900", "use": "cards, secciones, nav" },
      "elevated":    { "value": "#1E293B", "tw": "slate-800", "use": "inputs, elementos secundarios" },
      "overlay":     { "value": "rgba(2,6,23,0.95)",          "use": "nav fija / modal backdrop" },
      "glass":       { "value": "rgba(15,23,42,0.60)",        "use": "cards con backdrop-blur" },
      "glassDark":   { "value": "rgba(2,6,23,0.50)",          "use": "overlays de hero" }
    },
    "brand": {
      "cyan400":     { "value": "#22D3EE", "tw": "cyan-400", "use": "accent texto, íconos, laser" },
      "cyan500":     { "value": "#06B6D4", "tw": "cyan-500", "use": "botones CTA, badges sólidos" },
      "cyanGhost":   { "value": "rgba(6,182,212,0.10)",       "use": "fondo badge/card suave" },
      "cyanBorder":  { "value": "rgba(6,182,212,0.20)",       "use": "bordes de cards" },
      "cyanBorderMd":{ "value": "rgba(6,182,212,0.30)",       "use": "bordes activos / hover" },
      "cyanGlow":    { "value": "rgba(34,211,238,0.40)",      "use": "shadow glow botones" },
      "cyanGlowLg":  { "value": "rgba(34,211,238,0.15)",      "use": "shadow glow cards grandes" }
    },
    "text": {
      "primary":     { "value": "#F8FAFC", "tw": "slate-50",  "use": "títulos, texto destacado" },
      "secondary":   { "value": "#E2E8F0", "tw": "slate-200", "use": "cuerpo de texto" },
      "muted":       { "value": "#94A3B8", "tw": "slate-400", "use": "texto de apoyo, nav links" },
      "subtle":      { "value": "#64748B", "tw": "slate-500", "use": "placeholders, metadata" },
      "accent":      { "value": "#22D3EE", "tw": "cyan-400",  "use": "labels, subtítulos técnicos" },
      "onCyan":      { "value": "#020617", "tw": "slate-950", "use": "texto sobre fondo cyan" },
      "gold":        { "value": "#F59E0B", "tw": "amber-500", "use": "cifras de ahorro, highlights" }
    },
    "border": {
      "default":     { "value": "rgba(255,255,255,0.05)",     "use": "bordes sutiles white/5" },
      "muted":       { "value": "rgba(255,255,255,0.10)",     "use": "bordes estándar white/10" },
      "subtle":      { "value": "#1E293B", "tw": "slate-800", "use": "bordes de cards base" },
      "accent":      { "value": "rgba(6,182,212,0.20)",       "use": "borde cyan suave" },
      "accentMd":    { "value": "rgba(6,182,212,0.30)",       "use": "borde cyan medio" },
      "accentStrong":{ "value": "#06B6D4", "tw": "cyan-500",  "use": "borde cyan sólido (modal, CTA)" },
      "section":     { "value": "#0F172A", "tw": "slate-900", "use": "border-t entre secciones" }
    },
    "state": {
      "hover":       { "value": "#0F172A",                    "use": "bg hover de nav links" },
      "active":      { "value": "rgba(6,182,212,0.20)",       "use": "tab / card activa" },
      "disabled":    { "value": "rgba(148,163,184,0.30)",     "use": "elementos deshabilitados" }
    }
  },

  "typography": {
    "fontFamily": {
      "sans": ["Inter", "sans-serif"],
      "mono": ["JetBrains Mono", "monospace"]
    },
    "fontWeight": {
      "light":   300,
      "regular": 400,
      "semibold":600,
      "bold":    700,
      "black":   900
    },
    "fontSize": {
      "label":   { "value": "10px",   "use": "badges, etiquetas mono uppercase" },
      "labelSm": { "value": "11px",   "use": "sub-labels técnicos" },
      "xs":      { "value": "12px",   "use": "metadata, fechas" },
      "sm":      { "value": "14px",   "use": "body secundario, nav" },
      "base":    { "value": "16px",   "use": "body principal" },
      "lg":      { "value": "18px",   "use": "sub-titulos" },
      "xl":      { "value": "20px",   "use": "titulos de card" },
      "2xl":     { "value": "24px",   "use": "sección H3" },
      "3xl":     { "value": "30px",   "use": "sección H2 móvil" },
      "4xl":     { "value": "36px",   "use": "H2 desktop" },
      "6xl":     { "value": "60px",   "use": "hero H1 móvil" },
      "8xl":     { "value": "96px",   "use": "hero H1 desktop" }
    },
    "letterSpacing": {
      "tighter":  "-0.05em",
      "tight":    "-0.025em",
      "normal":   "0em",
      "wide":     "0.05em",
      "wider":    "0.1em",
      "widest":   "0.2em",
      "mono":     "0.3em",
      "label":    "0.4em"
    },
    "lineHeight": {
      "none":    1,
      "tight":   1.25,
      "snug":    1.375,
      "normal":  1.5,
      "relaxed": 1.625
    },
    "styles": {
      "heroTitle":    { "fontFamily": "sans", "fontSize": "6xl/8xl", "fontWeight": "black", "letterSpacing": "tighter", "textTransform": "uppercase", "lineHeight": "none" },
      "sectionTitle": { "fontFamily": "sans", "fontSize": "4xl/6xl", "fontWeight": "black", "letterSpacing": "tighter", "textTransform": "uppercase" },
      "cardTitle":    { "fontFamily": "sans", "fontSize": "2xl", "fontWeight": "black", "letterSpacing": "tighter", "textTransform": "uppercase" },
      "badge":        { "fontFamily": "mono", "fontSize": "label", "fontWeight": "black", "letterSpacing": "mono", "textTransform": "uppercase" },
      "techLabel":    { "fontFamily": "mono", "fontSize": "labelSm", "fontWeight": "black", "letterSpacing": "mono", "textTransform": "uppercase", "color": "cyan400" },
      "body":         { "fontFamily": "sans", "fontSize": "sm/base", "fontWeight": "regular", "color": "secondary" },
      "navLink":      { "fontFamily": "sans", "fontSize": "sm", "fontWeight": "bold", "letterSpacing": "wide", "textTransform": "uppercase" }
    }
  },

  "spacing": {
    "section": {
      "yMobile":  "3rem",
      "yDesktop": "6rem",
      "xMobile":  "1rem",
      "xDesktop": "1.5rem"
    },
    "card": {
      "sm":  "1rem",
      "md":  "1.25rem / 1.5rem",
      "lg":  "2rem",
      "xl":  "2.5rem",
      "2xl": "4rem"
    },
    "gap": {
      "sm":  "1rem",
      "md":  "1.5rem",
      "lg":  "2rem",
      "xl":  "3rem",
      "2xl": "4rem"
    }
  },

  "borderRadius": {
    "sm":    "0.5rem",
    "md":    "0.75rem",
    "lg":    "1rem",
    "xl":    "1.5rem",
    "2xl":   "2rem",
    "3xl":   "2.5rem",
    "4xl":   "3rem",
    "full":  "9999px"
  },

  "shadow": {
    "sm":         "0 1px 3px rgba(0,0,0,0.5)",
    "md":         "0 4px 6px rgba(0,0,0,0.4)",
    "lg":         "0 10px 15px rgba(0,0,0,0.5)",
    "xl":         "0 20px 25px rgba(0,0,0,0.5)",
    "2xl":        "0 25px 50px rgba(0,0,0,0.5)",
    "cyanSm":     "0 0 15px rgba(34,211,238,0.20)",
    "cyanMd":     "0 0 20px rgba(34,211,238,0.20)",
    "cyanLg":     "0 0 30px rgba(34,211,238,0.40)",
    "cyanXl":     "0 0 50px rgba(34,211,238,0.15)",
    "cyanModal":  "0 0 60px rgba(34,211,238,0.30)",
    "cyanLaser":  "0 0 25px 2px rgba(34,211,238,0.70)",
    "cyanBadge":  "0 0 20px rgba(34,211,238,0.20)"
  },

  "gradient": {
    "laser":       "linear-gradient(90deg, transparent, #22D3EE, #FFFFFF, #22D3EE, transparent)",
    "heroOverlay": "linear-gradient(to bottom, rgba(2,6,23,0.80), rgba(2,6,23,0.40))",
    "heroFade":    "linear-gradient(to right, #020617, rgba(2,6,23,0.80), rgba(2,6,23,0.40))",
    "cardDark":    "linear-gradient(to bottom-right, rgba(2,6,23,0.80), rgba(15,23,42,0.80))",
    "cyanGhost":   "linear-gradient(to right, rgba(6,182,212,0.20), rgba(34,211,238,0.20))",
    "highlight":   "linear-gradient(to right, rgba(8,47,73,0.40), rgba(23,37,84,0.40))"
  },

  "blur": {
    "sm":  "4px",
    "md":  "8px",
    "lg":  "12px"
  },

  "component": {
    "badge": {
      "solid": {
        "bg":           "#06B6D4",
        "text":         "#020617",
        "borderRadius": "9999px",
        "padding":      "0.25rem 0.75rem",
        "fontSize":     "10px",
        "fontWeight":   900,
        "textTransform":"uppercase",
        "letterSpacing":"0.3em"
      },
      "ghost": {
        "bg":           "rgba(6,182,212,0.10)",
        "border":       "1px solid rgba(6,182,212,0.30)",
        "text":         "#22D3EE",
        "borderRadius": "9999px",
        "padding":      "0.375rem 1rem",
        "fontSize":     "10px",
        "fontWeight":   900,
        "textTransform":"uppercase",
        "letterSpacing":"0.3em"
      },
      "mono": {
        "bg":           "transparent",
        "border":       "1px solid rgba(255,255,255,0.10)",
        "text":         "#E2E8F0",
        "borderRadius": "0.5rem",
        "padding":      "0.5rem 1rem",
        "fontFamily":   "JetBrains Mono",
        "fontSize":     "11px",
        "fontWeight":   900,
        "textTransform":"uppercase",
        "letterSpacing":"0.3em"
      }
    },
    "button": {
      "primary": {
        "bg":           "#06B6D4",
        "bgHover":      "#FFFFFF",
        "text":         "#020617",
        "borderRadius": "1rem",
        "padding":      "1rem 2.5rem",
        "fontSize":     "11px",
        "fontWeight":   900,
        "textTransform":"uppercase",
        "letterSpacing":"0.2em",
        "shadow":       "0 0 30px rgba(34,211,238,0.40)",
        "transition":   "all 300ms"
      },
      "secondary": {
        "bg":           "rgba(15,23,42,0.50)",
        "border":       "1px solid #1E293B",
        "text":         "#94A3B8",
        "textHover":    "#22D3EE",
        "borderHover":  "rgba(6,182,212,0.50)",
        "borderRadius": "0.75rem",
        "padding":      "0.75rem 1.5rem",
        "fontSize":     "12px",
        "fontWeight":   700,
        "transition":   "all 200ms"
      },
      "ghost": {
        "bg":           "rgba(6,182,212,0.20)",
        "border":       "2px solid #06B6D4",
        "text":         "#22D3EE",
        "borderRadius": "9999px",
        "padding":      "0.625rem 2rem",
        "fontSize":     "11px",
        "fontWeight":   900,
        "textTransform":"uppercase",
        "letterSpacing":"0.4em",
        "shadow":       "0 0 30px rgba(34,211,238,0.30)"
      }
    },
    "card": {
      "base": {
        "bg":           "rgba(15,23,42,0.60)",
        "border":       "1px solid rgba(255,255,255,0.10)",
        "borderRadius": "2rem",
        "shadow":       "0 25px 50px rgba(0,0,0,0.50)",
        "backdropBlur": "12px",
        "borderHover":  "rgba(6,182,212,0.50)",
        "transition":   "all 500ms"
      },
      "feature": {
        "bg":           "#020617",
        "border":       "1px solid #1E293B",
        "borderRadius": "0.75rem",
        "padding":      "2.5rem",
        "borderHover":  "rgba(34,211,238,0.40)",
        "transition":   "all 300ms"
      },
      "featureActive": {
        "bg":           "rgba(15,23,42,0.60)",
        "border":       "1px solid rgba(6,182,212,0.40)",
        "shadow":       "0 0 30px rgba(34,211,238,0.15)",
        "transform":    "scale(1.05)"
      },
      "info": {
        "bg":           "rgba(6,182,212,0.10)",
        "border":       "1px solid rgba(6,182,212,0.20)",
        "borderRadius": "0.75rem",
        "padding":      "1rem"
      },
      "glass": {
        "bg":           "rgba(15,23,42,0.40)",
        "border":       "1px solid rgba(255,255,255,0.05)",
        "borderRadius": "1rem",
        "backdropBlur": "12px"
      }
    },
    "nav": {
      "bg":           "rgba(2,6,23,0.95)",
      "border":       "1px solid rgba(15,23,42,0.80)",
      "backdropBlur": "12px",
      "height":       "64px",
      "shadow":       "0 4px 6px rgba(2,6,23,0.20)",
      "linkColor":    "#94A3B8",
      "linkHover":    "#22D3EE",
      "fontWeight":   700,
      "fontSize":     "14px",
      "letterSpacing":"0.05em",
      "textTransform":"uppercase"
    },
    "modal": {
      "bg":           "#0F172A",
      "border":       "2px solid #06B6D4",
      "borderRadius": "2.5rem",
      "shadow":       "0 0 60px rgba(34,211,238,0.30)",
      "backdropBg":   "rgba(2,6,23,0.95)",
      "backdropBlur": "12px",
      "padding":      "2rem / 3rem"
    },
    "accentLine": {
      "borderLeft":   "4px solid #06B6D4",
      "borderBottom": "2px solid rgba(6,182,212,0.20)"
    },
    "scrollbar": {
      "width":        "8px",
      "track":        "#020617",
      "thumb":        "#1E293B",
      "thumbHover":   "#22D3EE",
      "borderRadius": "10px"
    }
  },

  "animation": {
    "laser": {
      "gradient":  "linear-gradient(90deg, transparent, #22D3EE, #FFFFFF, #22D3EE, transparent)",
      "height":    "2px",
      "shadow":    "0 0 25px 2px rgba(34,211,238,0.70)",
      "duration":  "12s",
      "timing":    "linear",
      "iteration": "infinite"
    },
    "cta": {
      "hover":     "scale(1.05)",
      "active":    "scale(0.95)",
      "transition":"all 300ms cubic-bezier(0.4,0,0.2,1)"
    },
    "cardReveal": {
      "from":      "{ opacity: 0; transform: translateY(10px) }",
      "to":        "{ opacity: 1; transform: translateY(0) }",
      "duration":  "500ms",
      "timing":    "ease-out"
    }
  }
}
